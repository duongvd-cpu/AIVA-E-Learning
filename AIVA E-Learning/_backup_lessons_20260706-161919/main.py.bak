def _slug_to_title(slug: str) -> str:
    """Chuyển slug thư mục thành tiêu đề bài học từ README.md hoặc tên thư mục."""
    readme_path = LESSONS_VI_DIR / slug / "README.md"
    if readme_path.exists():
        with open(readme_path, "r", encoding="utf-8") as f:
            for line in f:
                line = line.strip()
                if line.startswith("# "):
                    return line[2:].strip()
    # Fallback: chuyển slug thành tên dễ đọc
    parts = slug.split("-", 1)
    return parts[1].replace("-", " ").title() if len(parts) > 1 else slug

def _rewrite_image_paths(html_content: str, lesson_slug: str) -> str:
    """
    Rewrite đường dẫn hình ảnh từ tương đối (Markdown) sang URL tuyệt đối (Web).
    Hỗ trợ 2 pattern:
    1. ../../../translated_images/vi/filename.HASH.webp → /lessons/images/translated/filename.HASH.webp
    2. ../../../NN-lesson/images/filename.png → /lessons/images/lesson/NN-lesson/filename.png
    """
    # Pattern 1: Ảnh WebP đã dịch (translated_images/vi/)
    html_content = re.sub(
        r'src="[./]*translated_images/vi/([^"]+)"',
        r'src="/lessons/images/translated/\1"',
        html_content
    )
    # Pattern 2: Ảnh gốc EN (../../../NN-lesson/images/file.png)
    def _rewrite_original_img(match):
        full_path = match.group(1)
        # Tìm phần thư mục bài + tên file (e.g. 13-multi-agent/images/file.png)
        return f'src="/lessons/images/lesson/{full_path}"'
    
    html_content = re.sub(
        r'src="[./]*(\d{2}-[^"]+/images/[^"]+)"',
        _rewrite_original_img,
        html_content
    )
    return html_content

def _rewrite_internal_links(html_content: str) -> str:
    """Rewrite link nội bộ giữa các bài thành lệnh JS điều hướng."""
    # Pattern: href="../05-tool-use/README.md" hoặc href="./05-tool-use/README.md"
    def _rewrite_link(match):
        slug = match.group(1)
        return f'href="javascript:void(0)" onclick="loadLesson(\'{slug}\')" class="internal-lesson-link"'
    
    html_content = re.sub(
        r'href="[./]*(\d{2}-[^/"]+)/README\.md"',
        _rewrite_link,
        html_content
    )
    return html_content

def _parse_youtube_thumbnail(md_content: str) -> dict | None:
    """Trích xuất YouTube video ID từ dòng đầu tiên của bài học (nếu có)."""
    first_line = md_content.split("\n")[0].strip()
    yt_match = re.search(r'youtu\.?be[./](?:watch\?v=)?([\w-]+)', first_line)
    if yt_match:
        return {"video_id": yt_match.group(1)}
    return None

# ── Sprint 4: Bộ xử lý nâng cao trải nghiệm đọc ──

def _clean_youtube_thumbnail(md_content: str) -> str:
    """Xóa dòng YouTube thumbnail + caption khỏi Markdown (tránh trùng iframe embed)."""
    lines = md_content.split("\n")
    cleaned = []
    skip_next_caption = False
    for i, line in enumerate(lines):
        stripped = line.strip()
        # Dòng thumbnail: [![...](image)](https://youtu.be/...)
        if re.match(r'^\[!\[.*\]\(.*\)\]\(https?://.*youtu\.?be', stripped):
            skip_next_caption = True
            continue
        # Sau dòng thumbnail: skip dòng trống, caption, blockquote caption
        if skip_next_caption:
            if stripped == '':
                continue
            # Caption dạng: > _(Nhấn/Nhấp vào hình ảnh...)_  hoặc  _(Click on the image...)_
            caption_keywords = ['Nhấn vào', 'Nhấp vào', 'Click on', 'click on', 'hình ảnh', 'video bài']
            if any(kw in stripped for kw in caption_keywords):
                # Nếu là dòng cuối cùng cần skip → reset flag
                skip_next_caption = False
                continue
            # Dòng không khớp → ngưng skip, giữ dòng này
            skip_next_caption = False
        cleaned.append(line)
    return "\n".join(cleaned)

def _parse_github_alerts(html_content: str) -> str:
    """
    Parse GitHub-style alerts trong HTML đã render từ blockquote.
    Input:  <blockquote><p>[!TIP]<br/>Nội dung mẹo.</p></blockquote>
    Output: <div class="alert alert-tip"><p><strong>💡 Mẹo:</strong> Nội dung mẹo.</p></div>
    """
    alert_map = {
        'TIP':       ('💡', 'Mẹo',       'alert-tip'),
        'IMPORTANT': ('❗', 'Quan trọng', 'alert-important'),
        'WARNING':   ('⚠️', 'Cảnh báo',   'alert-warning'),
        'CAUTION':   ('🔴', 'Chú ý',      'alert-caution'),
        'NOTE':      ('📝', 'Ghi chú',    'alert-note'),
    }

    for alert_type, (icon, label, css_class) in alert_map.items():
        # Pattern: <blockquote>\n<p>[!TYPE]<br/>\ncontent</p>\n</blockquote>
        pattern = re.compile(
            r'<blockquote>\s*<p>\[!' + alert_type + r'\]\s*(?:<br\s*/?>)?\s*',
            re.IGNORECASE
        )
        # Thay phần mở
        html_content = pattern.sub(
            f'<div class="alert {css_class}"><p><strong>{icon} {label}:</strong> ',
            html_content
        )

    # Đóng </blockquote> → </div> cho các alert đã mở
    # Tìm tất cả các đoạn alert chưa đóng đúng
    html_content = re.sub(
        r'(class="alert [^"]*">.*?)</p>\s*</blockquote>',
        r'\1</p></div>',
        html_content,
        flags=re.DOTALL
    )

    return html_content

def _clean_shield_badges(html_content: str) -> str:
    """Xóa hình ảnh shields.io badges (không phù hợp hiển thị local)."""
    # Xóa cả thẻ <a> bọc ngoài badge
    html_content = re.sub(
        r'<p>\s*<a[^>]*>\s*<img[^>]*shields\.io[^>]*/>\s*</a>\s*</p>',
        '',
        html_content
    )
    # Xóa badge đơn lẻ (không bọc <a>)
    html_content = re.sub(
        r'<img[^>]*shields\.io[^>]*/?>',
        '',
        html_content
    )
    return html_content

def _add_external_link_targets(html_content: str) -> str:
    """Thêm target='_blank' cho external links (trừ internal lesson links và YouTube)."""
    def _add_target(match):
        tag = match.group(0)
        # Bỏ qua nếu đã có target, onclick, hoặc là link nội bộ
        if 'target=' in tag or 'onclick=' in tag or 'javascript:' in tag:
            return tag
        # Thêm target và rel
        return tag.replace('<a ', '<a target="_blank" rel="noopener noreferrer" ')
    
    html_content = re.sub(r'<a\s+href="https?://[^"]*"[^>]*>', _add_target, html_content)
    return html_content


@app.get("/api/lessons")
async def list_lessons():
    """Trả về danh sách 24 bài học, nhóm theo 5 Modules."""
    modules_out = []
    for mod in COURSE_MODULES:
        lessons_out = []
        for slug in mod["lessons"]:
            lesson_dir = LESSONS_VI_DIR / slug
            if lesson_dir.exists():
                num = slug.split("-")[0]
                lessons_out.append({
                    "id": num,
                    "slug": slug,
                    "title": _slug_to_title(slug),
                    "has_demo": slug in DEMO_LESSONS,
                    "tier": "advanced" if slug in ADVANCED_LESSONS else "core"
                })
        modules_out.append({
            "id": mod["id"],
            "title": mod["title"],
            "color": mod["color"],
            "icon": mod["icon"],
            "lessons": lessons_out
        })
    return {"modules": modules_out}


@app.get("/api/lessons/{lesson_slug}")
async def get_lesson(lesson_slug: str):
    """
    Trả về nội dung HTML đã render từ Markdown của một bài học.
    
    Pipeline xử lý (Sprint 4):
    1. Đọc Markdown → Trích xuất YouTube ID
    2. Xóa YouTube thumbnail + caption (tránh trùng iframe)
    3. Render Markdown → HTML (fenced_code + tables + toc)
    4. Parse GitHub Alerts ([!TIP], [!IMPORTANT]...)
    5. Xóa shields.io badges
    6. Rewrite image paths (translated WebP + EN original)
    7. Rewrite internal links (→ loadLesson JS)
    8. Thêm target=_blank cho external links
    """
    readme_path = LESSONS_VI_DIR / lesson_slug / "README.md"
    if not readme_path.exists():
        raise HTTPException(status_code=404, detail=f"Bài học '{lesson_slug}' không tồn tại.")
    
    with open(readme_path, "r", encoding="utf-8") as f:
        md_content = f.read()
    
    # ── Step 1: Trích xuất YouTube video ──
    youtube = _parse_youtube_thumbnail(md_content)
    
    # ── Step 2: Xóa YouTube thumbnail + caption khỏi nội dung ──
    md_content = _clean_youtube_thumbnail(md_content)
    
    # Xác định Module ID
    module_id = None
    for mod in COURSE_MODULES:
        if lesson_slug in mod["lessons"]:
            module_id = mod["id"]
            break
    
    # ── Step 3: Render Markdown → HTML ──
    # Lưu ý: KHÔNG dùng codehilite (xung đột với highlight.js client-side)
    #         KHÔNG dùng nl2br (tạo <br/> thừa trong code blocks)
    html_content = markdown.markdown(
        md_content,
        extensions=["tables", "fenced_code", "toc"]
    )
    
    # ── Step 4: Parse GitHub Alerts ──
    html_content = _parse_github_alerts(html_content)
    
    # ── Step 5: Xóa shields.io badges ──
    html_content = _clean_shield_badges(html_content)
    
    # ── Step 6: Rewrite image paths ──
    html_content = _rewrite_image_paths(html_content, lesson_slug)
    
    # ── Step 7: Rewrite internal links ──
    html_content = _rewrite_internal_links(html_content)
    
    # ── Step 8: External links → new tab ──
    html_content = _add_external_link_targets(html_content)
    
    # ── Sprint 5: Tính thời gian đọc ──
    word_count = len(re.findall(r'\w+', md_content))
    reading_time = max(1, round(word_count / 200))  # ~200 từ/phút
    
    return {
        "slug": lesson_slug,
        "title": _slug_to_title(lesson_slug),
        "content_html": html_content,
        "module_id": module_id,
        "has_demo": lesson_slug in DEMO_LESSONS,
        "youtube": youtube,
        "reading_time": reading_time,  # Sprint 5
        "word_count": word_count        # Sprint 5
    }


