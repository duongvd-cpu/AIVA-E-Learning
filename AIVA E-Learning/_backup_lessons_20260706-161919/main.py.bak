# ── Tóm tắt bài học (Lesson Summary) ────────────────────────────────────────────
# Mục tiêu: tài liệu bài học khá dài & khó, cần "gói gọn" thành bản dễ hiểu cho
# người mới. Đọc full Markdown → nhờ Gemini tóm tắt ngắn gọn (TL;DR + ý chính +
# gợi ý thực hành) → cache theo slug để không gọi lại LLM mỗi lần mở.
_SUMMARY_CACHE: dict[str, dict] = {}

SUMMARIZER_PROMPT = """Bạn là trợ giảng của Sconnect cho khóa "AI Agents for Beginners".
Nhiệm vụ: tóm tắt một bài học (đang cho người MỚI HỌC) sao cho DỄ HIỂU, NGẮN GỌN.

Giọng điệu: thân thiện, trẻ trung, đi thẳng vào vấn đề (chuẩn brand Sconnect). Dùng tiếng Việt.
TUYỆT ĐỐI KHÔNG bịa thông tin ngoài nội dung bài. Không thêm lời chào/kết.

Trả về ĐÚNG định dạng Markdown sau (không bọc trong ```):

**TL;DR:** <1-2 câu nói cốt lõi bài học là gì>

**Ý chính:**
- <ý 1, mỗi ý 1 dòng, tối đa 6 ý, ngắn gọn>
- <ý 2>

**Thuật ngữ cần nhớ:** <2-4 thuật ngữ quan trọng, kèm giải thích siêu ngắn; nếu không có thì bỏ dòng này>

**Áp dụng / Thực hành:** <1-2 câu gợi ý người học nên thử gì, liên hệ Web Agent nếu hợp lý>
"""


def _normalize_summary_md(md: str) -> str:
    """Chèn dòng trống trước danh sách bullet để Markdown render đúng <ul>."""
    lines = md.split("\n")
    out: list[str] = []
    for ln in lines:
        is_bullet = re.match(r'^\s*[-*] ', ln)
        if is_bullet and out and out[-1].strip() and not re.match(r'^\s*[-*] ', out[-1]):
            out.append("")
        out.append(ln)
    return "\n".join(out)


async def _generate_lesson_summary(lesson_slug: str, md_content: str) -> str:
    """Gọi Gemini (không tool) sinh bản tóm tắt Markdown cho bài học."""
    # Giới hạn độ dài đầu vào để tiết kiệm token (đủ để nắm nội dung).
    clean = _clean_youtube_thumbnail(md_content)
    clean = re.sub(r'!\[[^\]]*\]\([^)]*\)', '', clean)  # bỏ ảnh
    body = clean[:12000]
    title = _slug_to_title(lesson_slug)

    summarizer = genai.GenerativeModel(
        model_name=GEMINI_MODEL,
        system_instruction=SUMMARIZER_PROMPT,
    )
    prompt = f"Tên bài: {title}\n\n--- NỘI DUNG BÀI ---\n{body}"
    result = await asyncio.to_thread(summarizer.generate_content, prompt)
    return (result.text or "").strip()


@app.get("/api/lessons/{lesson_slug}/summary")
async def get_lesson_summary(lesson_slug: str, refresh: bool = False):
    """Trả về bản tóm tắt dễ hiểu của bài học (HTML đã render + Markdown gốc)."""
    readme_path = LESSONS_VI_DIR / lesson_slug / "README.md"
    if not readme_path.exists():
        raise HTTPException(status_code=404, detail=f"Bài học '{lesson_slug}' không tồn tại.")

    if not refresh and lesson_slug in _SUMMARY_CACHE:
        return _SUMMARY_CACHE[lesson_slug]

    with open(readme_path, "r", encoding="utf-8") as f:
        md_content = f.read()

    try:
        summary_md = await _generate_lesson_summary(lesson_slug, md_content)
    except Exception as e:
        raise HTTPException(status_code=502, detail=f"Không tạo được tóm tắt: {e}")

    summary_html = markdown.markdown(_normalize_summary_md(summary_md), extensions=["tables"])
    payload = {
        "slug": lesson_slug,
        "title": _slug_to_title(lesson_slug),
        "summary_md": summary_md,
        "summary_html": summary_html,
        "cached": False,
    }
    _SUMMARY_CACHE[lesson_slug] = {**payload, "cached": True}
    return payload

# ── Sơ đồ tư duy (Mind Map) ─────────────────────────────────────────────────────
# Nhờ Gemini sinh mã Mermaid "mindmap" từ nội dung bài → frontend render bằng Mermaid.
_MINDMAP_CACHE: dict[str, dict] = {}

MINDMAP_PROMPT = """Bạn là trợ giảng của Sconnect. Hãy tạo SƠ ĐỒ TƯ DUY (mind map) cho một bài học,
xuất ra bằng cú pháp Mermaid "mindmap".

QUY TẮC BẮT BUỘC (nếu sai, sơ đồ sẽ không hiển thị được):
- Dòng đầu tiên đúng chữ: mindmap
- Dòng thứ hai là nút gốc dạng:   root((Tên chủ đề ngắn))
- Thụt lề bằng KHOẢNG TRẮNG (2 spaces mỗi cấp), tối đa 3 cấp con.
- Mỗi nhánh là nhãn NGẮN (2-6 từ), chỉ dùng chữ, số và khoảng trắng.
- TUYỆT ĐỐI KHÔNG dùng ký tự đặc biệt trong nhãn: ( ) [ ] { } : ; , " ' ` # / \\ | dấu chấm.
- 4-7 nhánh chính, mỗi nhánh 2-4 ý con. Nội dung bám sát bài, tiếng Việt.
- CHỈ trả về mã Mermaid, KHÔNG bọc trong ``` và KHÔNG thêm lời giải thích.

Ví dụ đúng:
mindmap
  root((Chu de chinh))
    Nhanh mot
      Y con A
      Y con B
    Nhanh hai
      Y con C
"""


def _clean_mermaid_mindmap(code: str) -> str:
    """Làm sạch output LLM để chắc chắn là mã mindmap hợp lệ."""
    code = (code or "").strip()
    # Bỏ hàng rào ```mermaid ... ```
    code = re.sub(r'^```[a-zA-Z]*\s*', '', code)
    code = re.sub(r'\s*```$', '', code).strip()
    # Bắt đầu từ dòng 'mindmap'
    idx = code.find("mindmap")
    if idx > 0:
        code = code[idx:]
    if not code.startswith("mindmap"):
        code = "mindmap\n  root((Bài học))\n    " + code.replace("\n", "\n    ")
    return code.strip()


async def _generate_lesson_mindmap(lesson_slug: str, md_content: str) -> str:
    clean = _clean_youtube_thumbnail(md_content)
    clean = re.sub(r'!\[[^\]]*\]\([^)]*\)', '', clean)
    body = clean[:12000]
    title = _slug_to_title(lesson_slug)
    gen = genai.GenerativeModel(model_name=GEMINI_MODEL, system_instruction=MINDMAP_PROMPT)
    prompt = f"Tên bài: {title}\n\n--- NỘI DUNG BÀI ---\n{body}"
    result = await asyncio.to_thread(gen.generate_content, prompt)
    return _clean_mermaid_mindmap(result.text or "")


@app.get("/api/lessons/{lesson_slug}/mindmap")
async def get_lesson_mindmap(lesson_slug: str, refresh: bool = False):
    """Trả về mã Mermaid mindmap cho bài học (frontend sẽ render)."""
    readme_path = LESSONS_VI_DIR / lesson_slug / "README.md"
    if not readme_path.exists():
        raise HTTPException(status_code=404, detail=f"Bài học '{lesson_slug}' không tồn tại.")
    if not refresh and lesson_slug in _MINDMAP_CACHE:
        return _MINDMAP_CACHE[lesson_slug]
    with open(readme_path, "r", encoding="utf-8") as f:
        md_content = f.read()
    try:
        mermaid_code = await _generate_lesson_mindmap(lesson_slug, md_content)
    except Exception as e:
        raise HTTPException(status_code=502, detail=f"Không tạo được sơ đồ tư duy: {e}")
    payload = {"slug": lesson_slug, "title": _slug_to_title(lesson_slug), "mermaid": mermaid_code, "cached": False}
    _MINDMAP_CACHE[lesson_slug] = {**payload, "cached": True}
    return payload


# Mount phục vụ hình ảnh gốc của từng bài (cho pattern 2)
# Quét tất cả thư mục bài có thư mục images/
for lesson_dir in sorted(REPO_ROOT.iterdir()):
    if lesson_dir.is_dir() and re.match(r'\d{2}-', lesson_dir.name):
        img_dir = lesson_dir / "images"
        if img_dir.exists():
            app.mount(
                f"/lessons/images/lesson/{lesson_dir.name}/images",
                StaticFiles(directory=str(img_dir)),
                name=f"lesson_img_{lesson_dir.name}"
            )


def proto_to_py(obj):
    """Đệ quy chuyển đổi cấu trúc Protobuf sang list/dict của Python."""
    obj_type = type(obj).__name__
    if obj_type == 'RepeatedComposite':
        return [proto_to_py(v) for v in obj]
    elif obj_type == 'MapComposite':
        return {k: proto_to_py(v) for k, v in obj.items()}
    elif isinstance(obj, dict):
        return {k: proto_to_py(v) for k, v in obj.items()}
    elif isinstance(obj, list):
        return [proto_to_py(v) for v in obj]
    else:
        return obj

class ChatRequest(BaseModel):
    message: str
    system_prompt: str | None = None
    lesson_slug: str | None = None  # Sprint 5: Lesson-Aware Context

@app.get("/", response_class=HTMLResponse)
async def serve_ui():
    """Phục vụ giao diện Chat UI."""
    with open("static/index.html", "r", encoding="utf-8") as f:
        return HTMLResponse(content=f.read())


# ── Hàm chạy Sub-Agent ───────────────────────────────────────────────────────
async def execute_sub_agent(skill_id: str, task_description: str, async_queue: asyncio.Queue):
    if skill_id not in SKILL_REGISTRY:
        return f"Lỗi: Kỹ năng '{skill_id}' không tồn tại."
        
    skill_info = SKILL_REGISTRY[skill_id]
    
    await async_queue.put(json.dumps({
        "type": "text", 
        "content": f"\n\n*(Quản đốc đang gọi Sub-agent: **{skill_info['name']}**...)*\n\n"
    }))
    
    sub_agent = genai.GenerativeModel(
        model_name=GEMINI_MODEL,
        system_instruction=skill_info["prompt"],
        tools=skill_info["tools"]
    )
    
    hook_manager.on_agent_start(skill_id, task_description)
    
    try:
        sub_chat = sub_agent.start_chat()
        sub_message = task_description
        
        while True:
            response = await asyncio.to_thread(sub_chat.send_message, sub_message)
            candidate = response.candidates[0]
            parts = candidate.content.parts
            
            has_function_call = any(hasattr(p, "function_call") and p.function_call.name for p in parts)
            
            if has_function_call:
                function_responses = []
                for part in parts:
                    if hasattr(part, "function_call") and part.function_call.name:
                        fn_name = part.function_call.name
                        fn_args = proto_to_py(dict(part.function_call.args))
                        
                        await async_queue.put(json.dumps({
                            "type": "tool_call",
                            "tool": f"[{skill_id}] {fn_name}",
                            "args": fn_args
                        }))
                        
                        hook_manager.before_tool_call(skill_id, fn_name, fn_args)
                        
                        fn_executor = ALL_FUNCTIONS.get(fn_name)
                        if fn_executor:
                            result = fn_executor(fn_args)
                        else:
                            result = f"Tool '{fn_name}' không tồn tại."
                            
                        hook_manager.after_tool_call(skill_id, fn_name, result)
                            
                        function_responses.append(
                            genai.protos.Part(
                                function_response=genai.protos.FunctionResponse(
                                    name=fn_name,
                                    response={"result": result}
                                )
                            )
                        )
                        
                        await async_queue.put(json.dumps({
                            "type": "tool_result",
                            "tool": f"[{skill_id}] {fn_name}",
                            "result": result
                        }))
                        
                sub_message = function_responses
                continue
            else:
                final_text = ""
                for part in parts:
                    if hasattr(part, "text") and part.text:
                        final_text += part.text
                
                await async_queue.put(json.dumps({
                    "type": "text", 
                    "content": f"\n\n*(Sub-agent **{skill_info['name']}** trả về kết quả)*\n\n"
                }))
                
                hook_manager.on_agent_finish(skill_id, final_text)
                
                return final_text

    except Exception as e:
        return f"Lỗi khi chạy Sub-agent: {str(e)}"


@app.post("/chat")
async def chat(req: ChatRequest):
    """
    Nhận tin nhắn người dùng và trả về phản hồi từ Orchestrator Agent.
    """
    global chat_history, model

    if req.system_prompt:
        model = genai.GenerativeModel(
            model_name=GEMINI_MODEL,
            system_instruction=req.system_prompt,
            tools=ORCHESTRATOR_TOOLS,
        )
    else:
        # Re-init model with Lesson-Aware context (Sprint 5)
        model = genai.GenerativeModel(
            model_name=GEMINI_MODEL,
            system_instruction=get_dynamic_system_prompt(lesson_slug=req.lesson_slug),
            tools=ORCHESTRATOR_TOOLS,
        )

    async def event_stream() -> AsyncGenerator[str, None]:
        global chat_history

        # ── Guardrails Check (Bài 18, 19) ──
        is_safe, warning_msg = check_input_safety(req.message)
        if not is_safe:
            yield f"data: {json.dumps({'type': 'error', 'message': warning_msg})}\n\n"
            return

        try:
            chat = model.start_chat(history=chat_history)
            current_message = req.message
            tool_calls_made = []
            
            # Queue to pass events from sub-agent back to the main SSE stream
            event_queue = asyncio.Queue()

            while True:
                response = await asyncio.to_thread(chat.send_message, current_message)
                candidate = response.candidates[0]
                parts = candidate.content.parts

                has_function_call = any(hasattr(p, "function_call") and p.function_call.name for p in parts)

                if has_function_call:
                    function_responses = []
                    for part in parts:
                        if hasattr(part, "function_call") and part.function_call.name:
                            fn_name = part.function_call.name
                            fn_args = proto_to_py(dict(part.function_call.args))

                            if fn_name == "delegate_task":
                                skill_id = fn_args.get("skill_name", "")
                                task_desc = fn_args.get("task_description")
                                
                                # Audit Trail Orchestrator
                                await event_queue.put(json.dumps({
                                    "type": "tool_call",
                                    "tool": f"[ORCHESTRATOR] 🎯 Gọi: {skill_id}",
                                    "args": {"task": task_desc}
                                }))
                                
                                # Giao việc thực sự
                                sub_task = asyncio.create_task(execute_sub_agent(skill_id, task_desc, event_queue))
                                
                                while not sub_task.done():
                                    try:
                                        msg = event_queue.get_nowait()
                                        yield f"data: {msg}\n\n"
                                    except asyncio.QueueEmpty:
                                        await asyncio.sleep(0.05)
                                        
                                # Drain remaining queue
                                while not event_queue.empty():
                                    msg = await event_queue.get()
                                    yield f"data: {msg}\n\n"
                                
                                result = sub_task.result()
                                tool_calls_made.append({"tool": fn_name, "result": "Delegated successfully."})
                                
                                # Emit đóng badge loading UI
                                yield f"data: {json.dumps({'type': 'tool_result', 'tool': f'[ORCHESTRATOR] 🎯 Gọi: {skill_id}', 'result': 'Hoàn thành'})}\n\n"

                            
                            elif fn_name == "create_execution_plan":
                                plan = fn_args.get("plan", "")
                                plan_event = json.dumps({"type": "text", "content": f"\n\n📋 **Kế hoạch (Planning):**\n{plan}\n\n"})
                                yield f"data: {plan_event}\n\n"
                                result = "Đã lập kế hoạch thành công. Hãy bắt đầu gọi delegate_task để thực thi."
                                tool_calls_made.append({"tool": fn_name, "result": "Lập kế hoạch thành công."})
                            
                            elif fn_name == "think_aloud":
                                thought = fn_args.get("thought", "")
                                thought_event = json.dumps({"type": "text", "content": f"\n\n🤔 **Tự suy ngẫm (Metacognition):**\n*{thought}*\n\n"})
                                yield f"data: {thought_event}\n\n"
                                result = "Đã suy ngẫm. Hãy áp dụng bài học này vào hành động tiếp theo."
                                tool_calls_made.append({"tool": fn_name, "result": "Suy ngẫm thành công."})
                                
                            else:
                                result = f"Orchestrator không có quyền chạy hàm '{fn_name}'"

                            function_responses.append(
                                genai.protos.Part(
                                    function_response=genai.protos.FunctionResponse(
                                        name=fn_name,
                                        response={"result": result}
                                    )
                                )
                            )

                            tool_result_event = json.dumps({
                                "type": "tool_result",
                                "tool": fn_name,
                                "result": "[Internal output sent to Orchestrator]"
                            })
                            yield f"data: {tool_result_event}\n\n"

                    current_message = function_responses
                    continue

                else:
                    final_text = ""
                    for part in parts:
                        if hasattr(part, "text") and part.text:
                            final_text += part.text

                    words = final_text.split(" ")
                    for i, word in enumerate(words):
                        chunk = word + (" " if i < len(words) - 1 else "")
                        text_event = json.dumps({"type": "text", "content": chunk})
                        yield f"data: {text_event}\n\n"
                        await asyncio.sleep(0.02)
                        
                    # ── LLM-as-a-Judge Evaluation (Bài 21) ──
                    print("\n⚖️ [JUDGE AGENT] Đang chấm điểm câu trả lời...")
                    evaluation = await evaluate_response(req.message, final_text)
                    print(f"    Điểm: {evaluation.get('score')}/10")
                    print(f"    Lý do: {evaluation.get('reason')}\n")
                    
                    badge = f"\n\n---\n*🛡️ Đánh giá bởi AI Judge: **{evaluation.get('score')}/10** điểm ({evaluation.get('reason')})*"
                    badge_event = json.dumps({"type": "text", "content": badge})
                    yield f"data: {badge_event}\n\n"
                    await asyncio.sleep(0.02)

                    chat_history = chat.history
                    done_event = json.dumps({"type": "done", "tool_calls": tool_calls_made})
                    yield f"data: {done_event}\n\n"
                    break

        except Exception as e:
            error_event = json.dumps({"type": "error", "message": str(e)})
            yield f"data: {error_event}\n\n"

    return StreamingResponse(event_stream(), media_type="text/event-stream")

@app.post("/reset")
async def reset_chat():
    global chat_history
    chat_history = []
    return {"status": "ok", "message": "Đã xóa lịch sử hội thoại."}

@app.get("/api/system_status")
async def get_system_status():
    """Trả về trạng thái toàn bộ hệ thống để phục vụ UI Sidebar và System Introspection"""
    
    # 1. Main Agent Tools
    orchestrator_tools = []
    if ORCHESTRATOR_TOOLS:
        for tool in ORCHESTRATOR_TOOLS:
            if hasattr(tool, "function_declarations"):
                for func in tool.function_declarations:
                    orchestrator_tools.append({
                        "name": func.name,
                        "description": getattr(func, "description", "")
                    })

    # 2. Sub-agents (Skills)
    skills_data = []
    for skill_id, skill_info in SKILL_REGISTRY.items():
        tools_list = []
        if skill_info["tools"]:
            for t in skill_info["tools"]:
                if hasattr(t, "function_declarations"):
                    # Xử lý FunctionDeclaration proto
                    for func in t.function_declarations:
                        tools_list.append({
                            "name": func.name,
                            "description": getattr(func, "description", "")
                        })
                elif callable(t):
                    # Xử lý function Python thông thường
                    tools_list.append({
                        "name": getattr(t, "__name__", str(t)),
                        "description": getattr(t, "__doc__", "")
                    })

        skills_data.append({
            "id": skill_id,
            "name": skill_info["name"],
            "description": skill_info["description"],
            "tools": tools_list
        })
        
    return {
        "orchestrator": {
            "name": "Main Agent",
            "role": "Orchestrator",
            "tools": orchestrator_tools
        },
        "skills": skills_data,
        "knowledge_bases": [
            {"name": "sconnect_knowledge", "type": "ChromaDB (Vector RAG)"},
            {"name": "knowledge_base.txt", "type": "Local Text Document"}
        ]
    }
