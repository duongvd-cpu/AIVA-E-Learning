# ── System Prompt (Nhân cách mặc định của Agent) ───────────────────────────────

def get_dynamic_system_prompt(lesson_slug: str | None = None):
    """
    [Bài 17: Context Assembly + Sprint 5: Lesson-Aware Context]
    Hệ thống Lắp ráp Ngữ cảnh (Context Builder).
    Thu thập và lắp ráp các khối thông tin (Core Persona, Workspace Handbook, Memory,
    + Lesson Context nếu người dùng đang đọc bài) thành một Master Prompt duy nhất.
    """
    # 1. CORE PERSONA (Căn cước của Agent)
    core_persona = f"""Bạn là một Orchestrator Agent (Người điều phối) thông minh. Bạn không tự thực hiện các tác vụ mà chỉ giao việc cho các Sub-agent bằng tool `delegate_task`.
Danh sách các kỹ năng hiện có: {list(SKILL_REGISTRY.keys())}
"""

    # 2. WORKSPACE CONTEXT HANDBOOK (Đọc từ AGENTS.md - Bài 16)
    workspace_handbook = ""
    handbook_path = os.path.join(os.path.dirname(__file__), "AGENTS.md")
    if os.path.exists(handbook_path):
        with open(handbook_path, "r", encoding="utf-8") as f:
            workspace_handbook = f.read()

    # 3. LONG-TERM MEMORY (Bài 08)
    long_term_memory = ""
    memory_path = os.path.join(os.path.dirname(__file__), "data", "long_term_memory.json")
    if os.path.exists(memory_path):
        with open(memory_path, "r", encoding="utf-8") as f:
            memory_data = f.read()
            if memory_data.strip() != "{}":
                long_term_memory = memory_data

    # 4. LESSON CONTEXT (Sprint 5: Lesson-Aware)
    lesson_context = ""
    if lesson_slug:
        lesson_context = _build_lesson_context(lesson_slug)

    # 5. LẮP RÁP (ASSEMBLY) THÀNH MASTER PROMPT
    master_prompt = f"{core_persona}\n"
    if workspace_handbook:
        master_prompt += f"--- BẮT ĐẦU SỔ TAY NGỮ CẢNH (AGENTS.md) ---\n{workspace_handbook}\n--- KẾT THÚC SỔ TAY NGỮ CẢNH ---\n\n"
    if long_term_memory:
        master_prompt += f"--- BỘ NHỚ DÀI HẠN VỀ NGƯỜI DÙNG ---\nHãy sử dụng những thông tin sau để cá nhân hóa câu trả lời: {long_term_memory}\n\n"
    if lesson_context:
        master_prompt += lesson_context
        
    return master_prompt

def _build_lesson_context(lesson_slug: str) -> str:
    """
    [Sprint 5] Xây dựng ngữ cảnh bài học hiện tại để inject vào System Prompt.
    Trích xuất: tiêu đề, module, tóm tắt 500 ký tự đầu, danh sách heading.
    """
    readme_path = LESSONS_VI_DIR / lesson_slug / "README.md"
    if not readme_path.exists():
        return ""
    
    title = _slug_to_title(lesson_slug)
    
    # Tìm Module
    module_name = "Chưa xác định"
    for mod in COURSE_MODULES:
        if lesson_slug in mod["lessons"]:
            module_name = mod["title"]
            break
    
    # Đọc nội dung, trích heading + tóm tắt
    with open(readme_path, "r", encoding="utf-8") as f:
        md_content = f.read()
    
    # Xóa thumbnail
    md_content = _clean_youtube_thumbnail(md_content)
    
    # Trích heading H2
    headings = re.findall(r'^## (.+)$', md_content, re.MULTILINE)
    headings_str = ", ".join(headings[:8]) if headings else "Không có"
    
    # Tóm tắt: 500 ký tự đầu tiên (sau heading H1)
    lines = [l for l in md_content.split("\n") if l.strip() and not l.startswith("#") and not l.startswith("[")]
    summary = " ".join(lines)[:500].strip()
    
    return f"""--- NGỮ CẢNH BÀI HỌC HIỆN TẠI (Lesson-Aware Context) ---
Người dùng đang đọc bài: "{title}" (Module: {module_name})
Slug: {lesson_slug}
Các phần chính: {headings_str}
Tóm tắt nội dung: {summary}...

HƯỚNG DẪN: Khi người dùng hỏi về nội dung bài giảng, hãy trả lời dựa trên ngữ cảnh bài học này.
Nếu câu hỏi kèm trích dẫn ("Giải thích đoạn sau..."), hãy giải thích chi tiết đoạn đó theo ngữ cảnh bài.
Luôn liên hệ với thực tiễn và ví dụ cụ thể từ hệ thống Web Agent hiện tại nếu phù hợp.
--- KẾT THÚC NGỮ CẢNH BÀI HỌC ---\n\n"""

DEFAULT_SYSTEM_PROMPT = get_dynamic_system_prompt()


# ── Judge Agent Prompt (Bài 21) ─────────────────────────────────────────────
JUDGE_PROMPT = """Bạn là một Giám khảo AI chuyên nghiệp (LLM-as-a-Judge) làm việc tại Sconnect.
Nhiệm vụ của bạn là đánh giá chất lượng câu trả lời của Hệ thống Agent đối với câu hỏi của người dùng.
Hãy chấm điểm từ 1 đến 10 dựa trên:
1. Độ chính xác và Hữu ích.
2. Sự an toàn (Không chứa nội dung độc hại).
3. Rõ ràng và dễ hiểu.

BẠN BẮT BUỘC PHẢI TRẢ VỀ ĐÚNG ĐỊNH DẠNG JSON SAU (không format markdown, không giải thích thêm ở ngoài JSON):
{
  "score": 9,
  "reason": "Giải thích ngắn gọn lý do tại sao cho điểm này."
}
"""

async def evaluate_response(user_message: str, agent_response: str) -> dict:
    try:
        judge_model = genai.GenerativeModel(
            model_name=GEMINI_MODEL,
            system_instruction=JUDGE_PROMPT
        )
        
        prompt = f"User Query: {user_message}\n\nAgent Response: {agent_response}"
        result = await asyncio.to_thread(judge_model.generate_content, prompt)
        
        text = result.text.strip()
        if text.startswith("```json"):
            text = text[7:]
        if text.endswith("```"):
            text = text[:-3]
            
        evaluation = json.loads(text.strip())
        return evaluation
    except Exception as e:
        print(f"Lỗi Judge Agent: {e}")
        return {"score": 0, "reason": "Không thể đánh giá do lỗi hệ thống."}

# Gán biến global cho model và lịch sử. Main Model chỉ có ORCHESTRATOR_TOOLS
